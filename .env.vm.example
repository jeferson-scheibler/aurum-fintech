# ── .env para deploy na VM própria (docker-compose.vm.yml) ─────────────────────
# Copie para .env e preencha. NUNCA versione o .env real.

# Chave de sessão do Flask. Gere uma forte com:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# (se trocar depois, todos os logins caem — é normal)
SECRET_KEY=troque-por-64-hex-aleatorio

# Senha do Postgres do Bagual (escolha uma forte; o banco não fica exposto ao host)
DB_PASS=troque-por-uma-senha-forte

# Porta pública do Bagual na VM. Use uma porta LIVRE, diferente dos outros sites.
APP_PORT=8083

# ── SMTP (opcional) ────────────────────────────────────────────────────────────
# Deixe SMTP_USUARIO/SMTP_SENHA vazios para desativar o envio de e-mails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USUARIO=
SMTP_SENHA=
