# ── Aplicação Flask ────────────────────────────────────────────────────────────
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-um-valor-aleatorio-de-64-hex

# Liga o debug do Flask (NUNCA "1" em produção)
FLASK_DEBUG=0

# Ambiente: "homolog" adiciona banner e prefixo [HOMOLOG] nos e-mails; "producao" envia normalmente
APP_ENV=producao

# ── Banco de dados PostgreSQL ──────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=financas_db
DB_USER=fintech
DB_PASS=CHANGE_ME

# ── Jenkins ────────────────────────────────────────────────────────────────────
JENKINS_ADMIN_PASSWORD=CHANGE_ME

# ── SMTP (opcional, só para notificações por e-mail) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USUARIO=
SMTP_SENHA=
